# Copy to .env and adjust. All values are optional for local dev.

# Port the API listens on
PORT=5000

# MongoDB connection string. If omitted, the server starts an in-memory
# MongoDB automatically (great for local dev — no install needed).
# For a real database use e.g. mongodb://127.0.0.1:27017/djewellry
# or a MongoDB Atlas SRV string.
# MONGO_URI=

# Secret used to sign admin JWTs (set a long random value in production)
JWT_SECRET=change-me-in-production

# Seeded admin credentials (used on first run / seeding)
ADMIN_EMAIL=admin@aurelia.test
ADMIN_PASSWORD=admin123

# Public origin of the client (for CORS). Defaults allow localhost dev.
CLIENT_ORIGIN=http://localhost:5173
